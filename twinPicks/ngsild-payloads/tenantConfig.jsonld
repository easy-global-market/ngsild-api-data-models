{
  "id": "urn:ngsi-ld:TenantConfig:MyCity",
  "type": "TenantConfig",
  "name": {
    "type": "Property",
    "value": "Tenant config for my city platform admin interface"
  },
  "logo": {
    "type": "JsonProperty",
    "description": {
      "type": "Property",
      "value": "Optional property. Used to display tenant logo instead of the default Twin Picks logo. Expected dimensions are: 55x55 px for small size and 195x55 px for large size"
    },
    "json": {
      "base64LogoShort": "data:image/png;base64...",
      "base64LogoLarge": "data:image/png;base64..."
    }
  },
  "hasActiveModules": [
    {
      "type": "Relationship",
      "object": "urn:ngsi-ld:Module:DeviceManagement",
      "datasetId": "urn:ngsi-ld:Dataset:DeviceManagement"
    },
    {
      "type": "Relationship",
      "object": "urn:ngsi-ld:Module:GuidedProvisioning",
      "datasetId": "urn:ngsi-ld:Dataset:GuidedProvisioning"
    }
  ],
  "primaryColor": {
    "type": "Property",
    "value": "#d9433f"
  },
  "welcomeMessage": {
    "type": "LanguageProperty",
    "languageMap": {
      "fr": "Bienvenue sur la plateforme Twin·Picks",
      "en": "Welcome to the Twin·Picks platform"
    }
  },
  "specificAccessPolicy": {
    "type": "Property",
    "value": "AUTH_READ"
  }
}
